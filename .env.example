# Local dev: use live API so admin saves appear on the deployed portfolio site.
# (.env.development sets this by default.)
# VITE_BACKEND_URL=https://portfolio-backend-ro4m.onrender.com

# Local-only backend (data will NOT show on the live frontend):
# VITE_BACKEND_URL=http://localhost:5000

# Production (Render standalone admin)
VITE_BACKEND_URL=https://portfolio-backend-ro4m.onrender.com
VITE_BASE_PATH=/

# When building for backend embed at /admin
# VITE_BASE_PATH=/admin/

# Public portfolio site (View Site button)
# VITE_FRONTEND_URL=https://your-frontend.onrender.com
